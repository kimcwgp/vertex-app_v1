{% if customer %}
  <script>
    window.customerData = {
      id: {{ customer.id | json }},
      email: {{ customer.email | json }},
      phone: {{ customer.phone | json }},
    // 'customer.tags' as an array for easy handling
      tags: {{ customer.tags | json }},
      companyName: {{ customer.current_company.name | json }},
      companyId: {{ customer.current_company.id | json }}
    };
  </script>
{% endif %}

<script>
  window.GOOGLE_URL = "{{ shop.metafields.vertex.spreadsheet_url.value }}";
</script>

<script src="{{ 'abandoned-cart-tracking.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Vertex: Abandoned Cart",
  "target": "body",
  "settings": []
}
{% endschema %}
